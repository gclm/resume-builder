# author: jf

# ========================================
# Docker 部署基础配置
# ========================================
# 注意：容器内的 localhost / 127.0.0.1 指向容器自身，不是宿主机。
# 如果 OpenAI-compatible 服务、Ollama、MySQL 或 PostgreSQL 运行在本机宿主机上，
# Docker 后端要使用 host.docker.internal 访问，例如 http://host.docker.internal:8080。
FRONTEND_PORT=3000
BACKEND_PORT=8999
SERVER_PORT=8999
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
APP_RAG_TOP_K=5
APP_INTERVIEW_RAG_TOP_K=4
APP_INTERVIEW_RAG_SIMILARITY_THRESHOLD=0.5
APP_INTERVIEW_RAG_TIMEOUT_SECONDS=3

# ========================================
# Docker 构建基础镜像
# ========================================
# 如果 Docker Hub 访问失败，可以把下面的镜像名改成你可访问的镜像仓库完整地址。
# 例如使用公司镜像仓库或本地已 docker load 的等价镜像标签。
NODE_IMAGE=node:22-alpine
NGINX_IMAGE=nginx:alpine
MAVEN_IMAGE=maven:3.9.9-eclipse-temurin-21
JRE_IMAGE=eclipse-temurin:21-jre-alpine
PYTHON_IMAGE=python:3.11-slim
MYSQL_IMAGE=mysql:8.4
PGVECTOR_IMAGE=pgvector/pgvector:pg17

# ========================================
# Docker 数据库连接
# ========================================
MYSQL_DATABASE=resume-builder
MYSQL_ROOT_PASSWORD=root
MYSQL_DATASOURCE_USERNAME=root
MYSQL_DATASOURCE_PASSWORD=root
MYSQL_DATASOURCE_URL=jdbc:mysql://mysql:3306/resume-builder?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
SPRING_MYSQL_DATASOURCE_URL=jdbc:mysql://mysql:3306/resume-builder?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
PYTHON_MYSQL_DATASOURCE_URL=mysql+pymysql://root:root@mysql:3306/resume-builder

POSTGRES_DB=resume-builder
POSTGRES_USER=pgvector
POSTGRES_PASSWORD=pgvector
PGVECTOR_PORT=5433
PGVECTOR_DATASOURCE_USERNAME=pgvector
PGVECTOR_DATASOURCE_PASSWORD=pgvector
PGVECTOR_DATASOURCE_URL=jdbc:postgresql://pgvector:5432/resume-builder
SPRING_PGVECTOR_DATASOURCE_URL=jdbc:postgresql://pgvector:5432/resume-builder
PYTHON_PGVECTOR_DATASOURCE_URL=postgresql+psycopg://pgvector:pgvector@pgvector:5432/resume-builder
PGVECTOR_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
PGVECTOR_CONNECT_TIMEOUT_SECONDS=8

# 如果 PostgreSQL + pgvector 已经运行在本机宿主机上，不要在 Docker URL 里写 localhost。
# 例如本机 pgvector 监听 5433 且数据库名为 resume-builder 时，可以改成：
# PGVECTOR_PORT=5433
# PGVECTOR_DATASOURCE_USERNAME=pgvector
# PGVECTOR_DATASOURCE_PASSWORD=your_pgvector_password
# PGVECTOR_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5433/resume-builder
# SPRING_PGVECTOR_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5433/resume-builder
# PYTHON_PGVECTOR_DATASOURCE_URL=postgresql+psycopg://pgvector:your_pgvector_password@host.docker.internal:5433/resume-builder
# 启动脚本检测到外部或宿主机 pgvector URL 后，会跳过 resume-builder-pgvector 容器。

# ========================================
# OpenAI 通用与 Chat
# ========================================
# 如果你的 OpenAI-compatible Chat 服务跑在本机 localhost:8080，
# 这里应写 http://host.docker.internal:8080，而不是 http://localhost:8080。
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=your_api_key_here
OPENAI_CHAT_BASE_URL=https://api.openai.com
OPENAI_CHAT_API_KEY=your_chat_api_key_here
OPENAI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
OPENAI_CHAT_MODEL=gpt-5.4
OPENAI_CHAT_TIMEOUT_SECONDS=25

# ========================================
# Embedding
# ========================================
# 如果 Ollama 跑在本机 localhost:11434，Docker 内应使用 http://host.docker.internal:11434。
EMBEDDING_PROVIDER=openai
EMBEDDING_DIMENSIONS=0
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com
OPENAI_EMBEDDING_API_KEY=your_embedding_api_key_here
OPENAI_EMBEDDINGS_PATH=/v1/embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_TIMEOUT_SECONDS=20
OLLAMA_EMBEDDING_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_TIMEOUT_SECONDS=45

# ========================================
# Vision OCR
# ========================================
OPENAI_VISION_BASE_URL=https://api.openai.com
OPENAI_VISION_API_KEY=your_vision_api_key_here
OPENAI_VISION_CHAT_COMPLETIONS_PATH=/v1/chat/completions
OPENAI_VISION_MODEL=gpt-4.1
OPENAI_VISION_TIMEOUT_SECONDS=40
OPENAI_VISION_DETAIL=high

# ========================================
# Realtime 语音
# ========================================
REALTIME_ASR_PROVIDER=dashscope
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_REALTIME_BASE_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
DASHSCOPE_REALTIME_MODEL=qwen3-asr-flash-realtime
DASHSCOPE_REALTIME_LANGUAGE=zh
DASHSCOPE_REALTIME_SAMPLE_RATE=16000
DASHSCOPE_REALTIME_VAD_THRESHOLD=0.2
DASHSCOPE_REALTIME_VAD_SILENCE_DURATION_MS=800
DASHSCOPE_REALTIME_OPEN_TIMEOUT_SECONDS=10
OPENAI_REALTIME_BASE_URL=https://api.openai.com
OPENAI_REALTIME_API_KEY=your_realtime_api_key_here
OPENAI_REALTIME_CLIENT_SECRETS_PATH=/v1/realtime/client_secrets
OPENAI_REALTIME_CALLS_PATH=/v1/realtime/calls
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_REALTIME_LANGUAGE=zh
OPENAI_REALTIME_TIMEOUT_SECONDS=120

# ========================================
# RAG 与扩展能力
# ========================================
RAG_CHUNK_SIZE=700
RAG_CHUNK_OVERLAP=70
RAG_MAX_FILE_SIZE_MB=10
AUTOGEN_ENABLED=false
