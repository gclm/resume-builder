# author: jf

# ========================================
# 基础服务配置
# ========================================
# 后端服务监听端口，前端代理默认走 8999，建议保持一致
SERVER_PORT=8999
# 允许跨域的前端地址（多个地址可用逗号分隔）
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
# RAG 检索默认返回条数
APP_RAG_TOP_K=5
# AI 面试专用 RAG 检索条数（未配置时会兜底到 APP_RAG_TOP_K）
APP_INTERVIEW_RAG_TOP_K=4
# AI 面试专用 RAG 相似度阈值（0-1，越高越严格）
APP_INTERVIEW_RAG_SIMILARITY_THRESHOLD=0.5
# AI 面试专用 RAG 检索超时秒数（超时后自动降级为不注入 RAG，避免卡首包）
APP_INTERVIEW_RAG_TIMEOUT_SECONDS=3

# ========================================
# OpenAI 通用/聊天模型配置
# ========================================
# 通用 OpenAI Base URL（聊天、视觉等会兜底用到）
OPENAI_BASE_URL=https://api.openai.com
# 通用 OpenAI API Key
OPENAI_API_KEY=your_api_key_here
# 聊天专用 Base URL（为空时回退到 OPENAI_BASE_URL）
OPENAI_CHAT_BASE_URL=https://api.openai.com
# 聊天专用 API Key（为空时回退到 OPENAI_API_KEY）
OPENAI_CHAT_API_KEY=your_api_key_here
# 聊天模型
OPENAI_CHAT_MODEL=gpt-5.4
# Chat Completions 路径
OPENAI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
# 聊天与流式请求超时（秒）
OPENAI_CHAT_TIMEOUT_SECONDS=25

# ========================================
# Embedding 配置（llama_index provider 切换）
# ========================================
# Embedding provider，可选: openai / ollama
EMBEDDING_PROVIDER=openai

# 当 EMBEDDING_PROVIDER=openai 时使用以下配置
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com
OPENAI_EMBEDDING_API_KEY=your_embedding_api_key_here
# 支持 OpenAI 官方模型名，也支持阿里百炼等 OpenAI 兼容网关提供的自定义 embedding model id
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# Embedding 超时（秒）
OPENAI_EMBEDDING_TIMEOUT_SECONDS=20

# 当 EMBEDDING_PROVIDER=ollama 时使用以下配置
OLLAMA_EMBEDDING_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Ollama Embedding 超时（秒）
OLLAMA_EMBEDDING_TIMEOUT_SECONDS=45

# ========================================
# 图片 OCR（知识库图片转 Markdown）
# ========================================
# 视觉模型
OPENAI_VISION_BASE_URL=https://api.openai.com
OPENAI_VISION_API_KEY=your_api_key_here
OPENAI_VISION_MODEL=gpt-4.1
OPENAI_VISION_TIMEOUT_SECONDS=40
# 视觉细节等级: low / high / original / auto
OPENAI_VISION_DETAIL=high

# ========================================
# 语音转写
# ========================================
OPENAI_SPEECH_BASE_URL=https://api.openai.com
OPENAI_SPEECH_API_KEY=your_api_key_here
OPENAI_SPEECH_TRANSCRIPTIONS_PATH=/v1/audio/transcriptions
OPENAI_SPEECH_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# ========================================
# Realtime 语音
# ========================================
OPENAI_REALTIME_BASE_URL=https://api.openai.com
OPENAI_REALTIME_API_KEY=your_api_key_here
OPENAI_REALTIME_CLIENT_SECRETS_PATH=/v1/realtime/client_secrets
OPENAI_REALTIME_CALLS_PATH=/v1/realtime/calls
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe
# Realtime 识别语言
OPENAI_REALTIME_LANGUAGE=zh

# ========================================
# MySQL（AI 面试会话）
# ========================================
# Python 后端推荐使用 mysql+pymysql:// 连接串
MYSQL_DATASOURCE_URL=mysql+pymysql://root:root@127.0.0.1:3306/resume-builder
MYSQL_DATASOURCE_USERNAME=root
MYSQL_DATASOURCE_PASSWORD=root

# ========================================
# PostgreSQL + pgvector（RAG 向量库）
# ========================================
PGVECTOR_DATASOURCE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/resume_builder_vector
PGVECTOR_DATASOURCE_USERNAME=pgvector
PGVECTOR_DATASOURCE_PASSWORD=pgvector
# 连接超时（秒）
PGVECTOR_CONNECT_TIMEOUT_SECONDS=8

# ========================================
# RAG 分块配置
# ========================================
# 单 chunk 字符数
RAG_CHUNK_SIZE=700
# chunk 重叠字符数
RAG_CHUNK_OVERLAP=70
# 上传文件大小上限（MB）
RAG_MAX_FILE_SIZE_MB=10

# ========================================
# AutoGen 开关
# ========================================
# 可选: true / false
AUTOGEN_ENABLED=false
